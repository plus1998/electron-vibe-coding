{
  "name": "electron-vibe-coding",
  "private": true,
  "version": "0.1.0",
  "description": "Commercial-grade Electron starter powered by Vite 8, Vue 3, shadcn-vue and a high-discipline AI coding workflow.",
  "type": "module",
  "main": "dist/main/index.js",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm run typecheck && node scripts/build.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 127.0.0.1 --strictPort",
    "start": "electron dist/main/index.js",
    "typecheck": "vue-tsc -b --pretty false"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "electron": "^41.0.3",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "shadcn-vue": "^2.4.3",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.2",
    "vue-tsc": "^3.2.6"
  }
}
